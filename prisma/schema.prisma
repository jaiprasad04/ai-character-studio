generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-1.0.x", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id                      String                    @id @default(cuid())
  name                    String?
  email                   String?                   @unique
  emailVerified           DateTime?
  image                   String?
  credits                 Int                       @default(0)
  accounts                Account[]
  sessions                Session[]
  CharacterStudioCreation CharacterStudioCreation[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model CharacterStudioCreation {
  id           String   @id @default(cuid())
  userId       String
  name         String
  backstory    String   @db.Text
  style        String
  personality  String
  avatarImage  String?  @db.Text
  greeting     String?  @db.Text
  systemPrompt String?  @db.Text
  status       String   @default("processing")
  requestId    String?  @unique
  error        String?  @db.Text
  creditCost   Int      @default(18)
  createdAt    DateTime @default(now())
  inputImage   String?  @db.Text
  aspectRatio  String   @default("1:1")
  resolution   String   @default("1k")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
